# Loaded automatically at startup when this file is copied to `.env` in the project root
# (real environment variables still override). Spring Boot does not load `.env` natively.
DB_USERNAME=gabriel
DB_PASSWORD=

# --- Policy (authorize) ---
GOVERNANCE_POLICY_SCOPE=GLOBAL
GOVERNANCE_POLICY_RUNTIME=JSON

# --- Audit / immutability ---
# BOTH = anchor to Fabric (or stub) AND keep a small metadata row here so GET /audit/verify works.
# DB_ONLY = no chain step (legacy / tests only).
# BLOCKCHAIN_ONLY = chain anchor only; metadata row is still stored for verify (not a duplicate of your EMR audit).
GOVERNANCE_AUDIT_STORAGE=BOTH

# true = no Hyperledger network required; ingest returns stub-tx-* evidence ids (good for local dev).
# false = real Fabric: you MUST set the FABRIC_* paths below and run a network + chaincode.
GOVERNANCE_BLOCKCHAIN_STUB=true

# --- API access ---
# Comma-separated browser origins for CORS (e.g. Next.js dev server on 3000).
GOVERNANCE_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
GOVERNANCE_AUTH_API_KEY_ENABLED=true
# Optional: legacy operator-only bootstrap (list all tenants, issue keys by tenant id). Prefer self-service /api/v1/auth + /api/v1/portal.
GOVERNANCE_ADMIN_SECRET=change-me-admin-secret
# Portal JWT (register/login + dashboard). Min 32 characters; generate a random string in production.
GOVERNANCE_JWT_SECRET=change-me-dev-jwt-secret-32chars-min!!
GOVERNANCE_JWT_EXPIRATION_SECONDS=86400
# Base URL embedded in dashboard curl snippets (your public API hostname in prod).
GOVERNANCE_PUBLIC_BASE_URL=http://localhost:8080
# Optional: paste an issued gdk_* key for curl/smoke; otherwise smoke script creates a tenant via admin.
GOVERNANCE_API_KEY=

# Optional OPA (only if GOVERNANCE_POLICY_RUNTIME=OPA)
OPA_URL=http://localhost:8181/v1/data/healthcare/authz
OPA_FAIL_OPEN=false

# --- Real Hyperledger Fabric (only when GOVERNANCE_BLOCKCHAIN_STUB=false) ---
BLOCKCHAIN_NETWORK=hyperledger-fabric
FABRIC_CONNECTION_PROFILE=
FABRIC_CHANNEL_NAME=mychannel
FABRIC_CHAINCODE_NAME=governance
FABRIC_WALLET_PATH=
FABRIC_IDENTITY_LABEL=
