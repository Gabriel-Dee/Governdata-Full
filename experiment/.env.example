# Experiment runner environment template
# Copy to `.env` before running experiment scripts, or export values in shell.

# Governance API endpoint and credentials used by experiment scripts
GOV_BASE_URL=http://localhost:8080
GOVERNANCE_API_KEY=

# PostgreSQL target used by tamper-validation steps in scripts
GOV_DB_NAME=governdata
# Optional explicit psql URL; when empty, scripts use GOV_DB_NAME
GOV_DB_URL=
