# -----------------------------
# Environment and secrets
# -----------------------------
.env
.env.*
**/.env
**/.env.*
*.pem
*.key
*.p12
*.pfx
*.jks
*.keystore
*.crt
*.csr
secrets/
**/secrets/

# Keep reproducibility templates tracked
!.env.example
!**/.env.example
!*.env.example
!**/*.env.example

