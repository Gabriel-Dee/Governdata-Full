# -----------------------------
node_modules/
**/node_modules/
.next/
**/.next/
dist/
**/dist/
build/
**/build/

# -----------------------------
# Java / Maven / Spring
# -----------------------------
target/
**/target/
.mvn/wrapper/maven-wrapper.jar

# -----------------------------
# Python
# -----------------------------
__pycache__/
**/__pycache__/
*.pyc
*.pyo
*.pyd
.venv/
venv/

