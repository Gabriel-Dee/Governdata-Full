# EHR/EMR backend environment template
# Copy to `.env` only for local convenience (Spring primarily uses application.properties/env vars).

# Optional governance API key propagated to outbound governance calls.
GOVERNANCE_API_KEY=

# Optional governance context defaults (used by governance client settings in application.properties)
GOVERNANCE_AUDIT_INGEST_ENABLED=true
GOVERNANCE_SOURCE_SYSTEM=ehr-emr-be
GOVERNANCE_TENANT_KEY=ehremr
GOVERNANCE_DEFAULT_REGION=US
GOVERNANCE_DEFAULT_LEGAL_BASIS=HIPAA
GOVERNANCE_DEFAULT_DEPARTMENT=General
GOVERNANCE_DEFAULT_LOCATION=hospital
GOVERNANCE_DEFAULT_CONSENT_GRANTED=true
GOVERNANCE_FAIL_OPEN=false

# If you override JWT secret via environment, use a long random value.
EHR_SECURITY_JWT_SECRET=change-me-local-dev-secret-key-change-me-12345
